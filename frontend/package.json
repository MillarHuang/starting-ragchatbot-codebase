{
  "name": "ragchatbot-frontend",
  "version": "1.0.0",
  "description": "Frontend for RAG Chatbot",
  "private": true,
  "scripts": {
    "format": "prettier --write \"**/*.{js,css,html}\"",
    "format:check": "prettier --check \"**/*.{js,css,html}\"",
    "lint": "eslint \"**/*.js\"",
    "lint:fix": "eslint --fix \"**/*.js\"",
    "quality": "prettier --check \"**/*.{js,css,html}\" && eslint \"**/*.js\""
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0"
  }
}
